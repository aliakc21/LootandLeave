# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_GUILD_ID=your_guild_id_here

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/lootandleave
# Set to true for Railway/Supabase hosted Postgres, false for most local databases
DATABASE_SSL=true
CHARACTER_REFRESH_INTERVAL_MINUTES=60
CHARACTER_REFRESH_BATCH_SIZE=25
DEFAULT_EVENT_CUT_TREASURY=0.30
DEFAULT_EVENT_CUT_ADVERTISER=0.10
DEFAULT_EVENT_CUT_BOOSTER=0.60

# Channel IDs (get these by right-clicking channels in Discord with Developer Mode enabled)
CHANNEL_CLIENT_CATEGORY=your_client_category_id_here
CHANNEL_BOOSTER_CATEGORY=your_booster_category_id_here
CHANNEL_APPLICATIONS=your_applications_channel_id_here
CHANNEL_JOBS=your_jobs_channel_id_here

# Weekday raid categories
# No IDs required right now.
# The bot automatically creates/fetches these categories by name when events are created:
# Sunday, Monday, Tuesday, Wednesday, Thursday, Friday, Saturday

# Auto-created log channels
# No IDs required right now.
# The bot automatically creates/fetches these channels under its logs category:
# event-logs, customer-logs, booster-logs

# Role IDs (get these by right-clicking roles in Discord with Developer Mode enabled)
# Leave empty if you want to use server Administrator permission as fallback
ROLE_ADMIN=your_admin_role_id_here
ROLE_MANAGEMENT=your_management_role_id_here
ROLE_ADVERTISER=your_advertiser_role_id_here
ROLE_RAID_LEADER=your_raid_leader_role_id_here
ROLE_BOOSTER=your_booster_role_id_here
ROLE_CLIENT=your_client_role_id_here

# Commission Rates (as decimals, must sum to 1.0)
# These can also be set via /config command
COMMISSION_TREASURY=0.30
COMMISSION_ADVERTISER=0.10
COMMISSION_BOOSTER=0.60
